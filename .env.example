# ── OpenAI — used by Google ADK via LiteLLM (platform.openai.com → API keys) ─
OPENAI_API_KEY=sk-...

# ── Gmail OAuth (Google Cloud Console → Credentials → OAuth 2.0 Client) ───────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/callback

# ── Slack (api.slack.com → Your App → OAuth & Permissions / Basic Info) ───────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# ── Gmail Pub/Sub (Google Cloud Console → Pub/Sub → Topics) ──────────────────
GMAIL_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-push

# ── Agent behaviour ───────────────────────────────────────────────────────────
EMAIL_PROVIDER=fake           # fake | gmail | yahoo
DRY_RUN=true                  # set false to write to Gmail
SLACK_DIGEST_CHANNEL=#general
DIGEST_TIMEZONE=America/Toronto
