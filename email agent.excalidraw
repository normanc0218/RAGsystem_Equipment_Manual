      "boundElements": [],
      "updated": 1778183706597,
      "link": null,
      "locked": false,
      "text": "Responsibility\n\nsyncs user-defined Gmail labels into the semantic group DB\nbootstraps label-based groups and processed markers\nFunction\n\nread Gmail labels\ncreate or update Firestore group seeds\ngenerate label embeddings\nmark emails under those labels as processed\nonly run on first setup or when new labels appear",
      "fontSize": 12.051031808751818,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Responsibility\n\nsyncs user-defined Gmail labels into the semantic group DB\nbootstraps label-based groups and processed markers\nFunction\n\nread Gmail labels\ncreate or update Firestore group seeds\ngenerate label embeddings\nmark emails under those labels as processed\nonly run on first setup or when new labels appear",
      "autoResize": true,
      "lineHeight": 1.25
    },
