      "updated": 1778183630971,
      "link": null,
      "locked": false,
      "text": "- on /organize:\n    optionally trigger mailbox sync if this is first run or labels changed\n    run inbox processing\n    run summarization\n    collect audit log entries and return a report\n- on /digest:\n    read recent activity and group state\n    generate a reminder digest\n- on /undo:\n    query the action log\n    invoke undo logic\n    return undo result",
      "fontSize": 8.533333333333339,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- on /organize:\n    optionally trigger mailbox sync if this is first run or labels changed\n    run inbox processing\n    run summarization\n    collect audit log entries and return a report\n- on /digest:\n    read recent activity and group state\n    generate a reminder digest\n- on /undo:\n    query the action log\n    invoke undo logic\n    return undo result",
      "autoResize": true,
      "lineHeight": 1.25
    },
